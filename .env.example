# ─────────────────────────────────────────────────────────
# 환경변수 설정 파일 (.env.example → .env로 복사 후 값 수정)
# 이 파일은 Git에 커밋해도 됩니다 (.env는 절대 커밋 금지!)
# ─────────────────────────────────────────────────────────

# Database
DB_NAME=spaceres_db
DB_USERNAME=spaceres_user
DB_PASSWORD=your_db_password_here
DB_ROOT_PASSWORD=your_root_password_here

# JWT (최소 32자 이상의 랜덤 문자열)
# 생성 방법: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-long-change-this

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here
